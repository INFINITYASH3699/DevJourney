// prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  email          String      @unique
  password       String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  playlists      Playlist[]
  milestones     Milestone[]
  streak         Int         @default(0)
  lastActive     DateTime    @default(now())
  totalWatchTime Int         @default(0)
  
  // NEW: Daily schedule - hours available per day
  dailySchedule  Json?       // { "monday": 240, "tuesday": 180, ... } in minutes
  preferences    Json?       // User preferences like theme, notifications, etc.
}

model Playlist {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String    @db.ObjectId
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlistId      String    @unique
  title           String
  description     String?
  category        String
  thumbnailUrl    String?
  totalVideos     Int       @default(0)
  completedVideos Int       @default(0)
  totalDuration   Int       @default(0) // Total duration in seconds
  videos          Video[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastWatchedAt   DateTime?
  
  // NEW: Target/Deadline features
  targetDate      DateTime? // When user wants to complete this playlist
  dailyTarget     Int?      // Daily target in minutes (auto-calculated or manual)
  targetVideos    Int?      // Daily target videos count
  isOverdue       Boolean   @default(false)
  overdueFrom     DateTime? // When it became overdue

  @@index([userId])
  @@index([userId, category])
  @@index([category])
}

model Video {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  playlistId       String      @db.ObjectId
  playlist         Playlist    @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  videoId          String
  title            String
  description      String?
  thumbnailUrl     String?
  duration         String?
  durationSeconds  Int         @default(0)
  position         Int
  status           VideoStatus @default(NOT_STARTED)
  lastWatchedAt    DateTime?
  completedAt      DateTime?
  notes            String?
  aiTakeaways      String?     // Full detailed takeaways JSON
  shortTakeaway    String?     // NEW: Brief 1-2 line summary for card display
  takeawaysStatus  String?     @default("none")
  needsPractice    Boolean     @default(false)
  practiceNotes    String?
  watchProgress    Int         @default(0) // NEW: Progress in seconds for resume
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([playlistId])
  @@index([status])
  @@index([playlistId, status])
  @@index([playlistId, position])
  @@index([needsPractice])
}

enum VideoStatus {
  NOT_STARTED
  WATCHING
  COMPLETED
}

model Milestone {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  targetDate  DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  category    String
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([userId, completed])
}